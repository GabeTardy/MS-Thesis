<Group hide-input="false" labelreference="L127019" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Extras: Create 3D Plots of Parameters C0-C4 and attempt surface fits satisfying conditions at etaE = 1
ParamPlots := Vector(5):
cvals := [[], [], [], [], []]:
fitEqns := [

a + b*ln(1/eta__E)*(ln(m) - 1/m),
1/m - 1 + a*m/eta__E,
a*m/eta__E + c,
a/((m+b)*(eta__E+c)),
a + b*ln(eta__E)*(ln(m) - 1/m)

];
AttemptedFits := Vector(5);

for j from 1 to 5 do:
for i from 1 to RowDimension(R2) do:
cvals[j] := [seq(cvals[j]), parameterVals[i][j]]:
od:

# Attempt to perform curve fit
AttemptedFits[j] := Fit(fitEqns[j], cvals[j], [eta__E, m]):

ParamPlots[j] := display(surfdata(convert(cvals[j], Array), style=surface, transparency = 0.6, colorscheme=&quot;Viridis&quot;), plot3d(AttemptedFits[j], eta__E=0..4, m=0.125..1, color=&quot;IBMx 1&quot;), pointplot3d(convert(cvals[j], Array), color = black), labels=['eta__E', 'm', C[j-1]], size=[850, 500]):

od:

AttemptedFits;

for i from 1 to 5 do:
ParamPlots[i];
od;</Text-field>
</Input>
