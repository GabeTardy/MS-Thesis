<Group hide-input="false" labelreference="L126922" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Extras: Create 3D Plot of Critical Loads
thesisStyle3d := proc(plotFunc):

return display(plotFunc, thickness=3, font=[&quot;Times New Roman&quot;, roman, 16], labelfont=[&quot;Cambria Math&quot;, italic, 16], axis=[thickness=2, tickmarks=[thickness=0]]);

end proc:

cpvst2 := []:
cpvsb2 := []:
for i from 1 to RowDimension(critPointsValsST) do
critPointsValsST[i];
if critPointsValsST[i] &lt;&gt; 0 then
cpvst2 := [seq(cpvst2), critPointsValsST[i]];
cpvsb2 := [seq(cpvsb2<Font bold="false">), critPointsValsSB[i]</Font>];
fi:
od:

snapThrough :=  cpvst2:
snapBack := cpvsb2:
m := 'm':
rr := 'rr':

fitEqnSB := Fit((2/(eta__E+1) + b)*(1 - 2*sqrt(3)/9*(1-m)^(3/2)/m), snapBack, [eta__E, m]);
#fitEqnST := Fit((a*eta__E + b)*(1 + 2*sqrt(3)/9*(1-m)^(3/2)/m), snapThrough, [eta__E, m]);
fitEqnST := (1 + 2*sqrt(3)/9*(1-m)^(3/2)/m);
fitEqnSB := (2/(eta__E+1)) - 2*sqrt(3)/9*(1-m)^(3/2)/m;

fitEqnPlotSB := plot3d(fitEqnSB, eta__E=0..4, m=0.125..1, color=&quot;IBMx 2&quot;, transparency = 0.6):
fitEqnPlotST := plot3d(fitEqnST, eta__E=0..4, m=0.125..1, color=&quot;IBMx 1&quot;, transparency = 0.6):

snapThroughPlot := surfdata(convert(snapThrough, Array), labels=['eta__E', 'm', 'u__crit'], style=surface, transparency = 0.6, color=&quot;IBMx 1&quot;):
snapBackPlot := surfdata(convert(snapBack, Array), labels=['eta__E', 'm', 'u__crit'],  style=surface, transparency = 0.6, color=&quot;IBMx 1&quot;):

noSnapThrough := simplify(solve(fitEqnST = fitEqnSB, eta__E));

noSnapBack := simplify(solve(fitEqnSB = 0, eta__E));

slicePos := 0.5;
slicePlot1 := spacecurve(subs(m=slicePos, {[eta__E, m, fitEqnST], [eta__E, m, fitEqnSB]}), eta__E = 0..4, color=[&quot;IBMx 1&quot;, &quot;IBMx 2&quot;]):

interfaceNST := spacecurve([noSnapThrough, m, 1 + (2*sqrt(3)*(1 - m)^(3/2))/(9*m)], m=0.1..1, labels=['eta__E', 'm', 'u__crit'], color=black):
interfaceNSB := spacecurve([noSnapBack, m, 0], m=0.1..0.9, labels=['eta__E', 'm', 'u__crit'], color=black):
interfaceNSBPlane := plot3d(0, eta__E=0..4, m=0..1, color=black, transparency=0.9):

snapThroughPlotP := pointplot3d(convert(snapThrough, Array), labels=['eta__E', 'm', 'u__crit'], color = black):
snapBackPlotP := pointplot3d(convert(snapBack, Array), labels=['eta__E', 'm', 'u__crit'], color=black):
surfaces := display(snapThroughPlot, snapBackPlot, colorscheme=&quot;Viridis&quot;, overrideoptions):
thesisStyle3d(display(surfaces, snapThroughPlotP, snapBackPlotP, fitEqnPlotSB, fitEqnPlotST, interfaceNST, interfaceNSB, interfaceNSBPlane, slicePlot1, view=[0..4, 0..1, -2..3.5]));</Text-field>
</Input>
